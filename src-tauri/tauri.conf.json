{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnyPaste",
  "version": "0.1.0",
  "identifier": "app.anypaste.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AnyPaste",
        "width": 1180,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "A beautiful local clipboard manager.",
    "longDescription": "AnyPaste keeps clipboard history searchable, private and organized across macOS, Windows and Linux."
  }
}
